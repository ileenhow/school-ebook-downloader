{
  "name": "school-ebook-downloader",
  "version": "0.2.0",
  "private": true,
  "description": "Chrome extension for downloading textbooks from SmartEdu pages.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "zip": "node scripts/package-extension.mjs",
    "release:build": "pnpm typecheck && pnpm build && pnpm zip",
    "cws:upload": "node scripts/chrome-web-store-publish.mjs --no-publish",
    "cws:publish": "node scripts/chrome-web-store-publish.mjs",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.33",
    "@types/node": "^25.9.3",
    "typescript": "^5.9.3",
    "vite": "^7.2.7"
  }
}
